generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum StatusLancamento {
  PAGO
  PENDENTE
}

enum OrigemLancamento {
  MANUAL
  WHATSAPP
  RECORRENTE
}

model Categoria {
  id           Int             @id @default(autoincrement())
  nome         String
  tipo         TipoLancamento
  lancamentos  Lancamento[]
  recorrentes  Recorrente[]
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  @@unique([nome, tipo])
  @@map("categorias")
}

model Lancamento {
  id           Int               @id @default(autoincrement())
  tipo         TipoLancamento
  valor        Decimal           @db.Decimal(12, 2)
  descricao    String
  observacao   String?
  data         DateTime
  status       StatusLancamento  @default(PENDENTE)
  contabiliza  Boolean           @default(true)
  categoriaId  Int
  recorrenteId Int?
  origem       OrigemLancamento  @default(MANUAL)
  categoria    Categoria         @relation(fields: [categoriaId], references: [id])
  recorrente   Recorrente?       @relation(fields: [recorrenteId], references: [id])
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  @@index([data])
  @@index([categoriaId])
  @@index([recorrenteId])
  @@unique([recorrenteId, data])
  @@map("lancamentos")
}

model Recorrente {
  id           Int             @id @default(autoincrement())
  descricao    String
  valor        Decimal         @db.Decimal(12, 2)
  tipo         TipoLancamento
  categoriaId  Int
  dataInicio   DateTime
  dataFim      DateTime?
  diaPagamento Int?
  ativo        Boolean         @default(true)
  categoria    Categoria       @relation(fields: [categoriaId], references: [id])
  lancamentos  Lancamento[]
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  @@index([dataInicio])
  @@index([dataFim])
  @@index([categoriaId])
  @@map("recorrentes")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  senha        String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}
